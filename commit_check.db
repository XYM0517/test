  "range-cache-c:/users/34948/documents/trae_projects/new_project/check_global_db.py": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":41,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":41,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originAcceptText\":\"import sqlite3\\nimport os\\nimport shutil\\n\\ndb_path = r\\\"C:\\\\Users\\\\34948\\\\AppData\\\\Roaming\\\\Trae CN\\\\User\\\\globalStorage\\\\state.vscdb\\\"\\ntemp_path = r\\\"c:\\\\Users\\\\34948\\\\Documents\\\\trae_projects\\\\new_project\\\\global_check.vscdb\\\"\\n\\nshutil.copy2(db_path, temp_path)\\n\\nconn = sqlite3.connect(temp_path)\\ncur = conn.cursor()\\n\\nprint(\\\"===== 1. 表结构 =====\\\")\\ncur.execute(\\\"SELECT name FROM sqlite_master WHERE type='table'\\\")\\nprint(\\\"Tables:\\\", cur.fetchall())\\n\\nprint(\\\"\\\\n===== 2. 搜索所有包含 range-cache 的 key =====\\\")\\ncur.execute(\\\"SELECT key FROM ItemTable WHERE key LIKE '%range-cache%' OR key LIKE '%rangeCache%' LIMIT 30\\\")\\nkeys = cur.fetchall()\\nprint(f\\\"找到 {len(keys)} 条:\\\")\\nfor k in keys:\\n    print(f\\\"  {k[0]}\\\")\\n\\nprint(\\\"\\\\n===== 3. 搜索 test3/门户/contribution 相关 key =====\\\")\\ncur.execute(\\\"SELECT key FROM ItemTable WHERE key LIKE '%test3%' OR key LIKE '%contribution%' OR key LIKE '%门户%' OR key LIKE '%accept%' LIMIT 30\\\")\\nkeys = cur.fetchall()\\nprint(f\\\"找到 {len(keys)} 条:\\\")\\nfor k in keys:\\n    print(f\\\"  {k[0]}\\\")\\n\\nprint(\\\"\\\\n===== 4. 搜索 value 中包含 test3 或 range-cache 的记录 =====\\\")\\ncur.execute(\\\"SELECT key, length(value) as vlen FROM ItemTable WHERE value LIKE '%test3%' OR value LIKE '%range-cache%' LIMIT 30\\\")\\nvals = cur.fetchall()\\nprint(f\\\"找到 {len(vals)} 条:\\\")\\nfor k in vals:\\n    print(f\\\"  key={k[0]}, value长度={k[1]}\\\")\\n\\nprint(\\\"\\\\n===== 5. 搜索包含 '门户首页' 或 'aiScene' 的 value =====\\\")\\ncur.execute(\\\"SELECT key, length(value) as vlen FROM ItemTable WHERE value LIKE '%门户首页%' OR value LIKE '%aiScene%' OR value LIKE '%behaviorType%' LIMIT 30\\\")\\nvals = cur.fetchall()\\nprint(f\\\"找到 {len(vals)} 条:\\\")\\nfor k in vals:\\n    print(f\\\"  key={k[0]}, value长度={k[1]}\\\")\\n\\nprint(\\\"\\\\n===== 6. 所有 key 列表（前50条）=====\\\")\\ncur.execute(\\\"SELECT key FROM ItemTable ORDER BY key LIMIT 50\\\")\\nfor k in cur.fetchall():\\n    print(f\\\"  {k[0]}\\\")\\n\\nconn.close()\\nos.remove(temp_path)\\n\",\"originTextLength\":1778,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1783576033850}]",
  "range-cache-c:/users/34948/documents/trae_projects/new_project/check_all_ws.py": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":47,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":47,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originAcceptText\":\"import sqlite3\\nimport os\\nimport shutil\\n\\nworkspaces = [\\n    r\\\"C:\\\\Users\\\\34948\\\\AppData\\\\Roaming\\\\Trae CN\\\\User\\\\workspaceStorage\\\\44839a1238981b4c6a54fb0a0e0ce67c\\\\state.vscdb\\\",\\n    r\\\"C:\\\\Users\\\\34948\\\\AppData\\\\Roaming\\\\Trae CN\\\\User\\\\workspaceStorage\\\\fb232bb784cfa120e8b700e3c8df2cf2\\\\state.vscdb\\\",\\n    r\\\"C:\\\\Users\\\\34948\\\\AppData\\\\Roaming\\\\Trae CN\\\\User\\\\workspaceStorage\\\\8522d2f518c4a51a18c0ff9b1e56e46d\\\\state.vscdb\\\",\\n]\\n\\nfor db_path in workspaces:\\n    print(f\\\"\\\\n{'='*60}\\\")\\n    print(f\\\"数据库: {db_path}\\\")\\n    print(f\\\"{'='*60}\\\")\\n\\n    temp_path = r\\\"c:\\\\Users\\\\34948\\\\Documents\\\\trae_projects\\\\new_project\\\\ws_check.vscdb\\\"\\n    shutil.copy2(db_path, temp_path)\\n\\n    conn = sqlite3.connect(temp_path)\\n    cur = conn.cursor()\\n\\n    # 检查 workspace.json\\n    ws_json = os.path.join(os.path.dirname(db_path), \\\"workspace.json\\\")\\n    if os.path.exists(ws_json):\\n        with open(ws_json, 'r', encoding='utf-8') as f:\\n            print(f\\\"workspace.json: {f.read()}\\\")\\n\\n    # 搜索 range-cache\\n    cur.execute(\\\"SELECT key FROM ItemTable WHERE key LIKE '%range-cache%' LIMIT 20\\\")\\n    keys = cur.fetchall()\\n    print(f\\\"range-cache key 数量: {len(keys)}\\\")\\n    for k in keys:\\n        print(f\\\"  {k[0]}\\\")\\n\\n    # 搜索 test3\\n    cur.execute(\\\"SELECT key FROM ItemTable WHERE key LIKE '%test3%' LIMIT 10\\\")\\n    test3_keys = cur.fetchall()\\n    print(f\\\"test3 key 数量: {len(test3_keys)}\\\")\\n    for k in test3_keys:\\n        print(f\\\"  {k[0]}\\\")\\n\\n    # 搜索 value 中包含 range-cache\\n    cur.execute(\\\"SELECT key, length(value) FROM ItemTable WHERE value LIKE '%range-cache%' LIMIT 10\\\")\\n    vals = cur.fetchall()\\n    print(f\\\"value 包含 range-cache 的记录: {len(vals)}\\\")\\n    for k in vals:\\n        print(f\\\"  key={k[0]}, vlen={k[1]}\\\")\\n\\n    # 搜索 contribution\\n    cur.execute(\\\"SELECT key FROM ItemTable WHERE key LIKE '%contribution%' OR key LIKE '%accept%' LIMIT 10\\\")\\n    contrib_keys = cur.fetchall()\\n    print(f\\\"contribution/accept key: {len(contrib_keys)}\\\")\\n    for k in contrib_keys:\\n        print(f\\\"  {k[0]}\\\")\\n\\n    conn.close()\\n    os.remove(temp_path)\\n\",\"originTextLength\":1970,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1783576048955}]",
  "range-cache-c:/users/34948/documents/trae_projects/new_project/check_detail.py": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":45,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":45,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originAcceptText\":\"import sqlite3\\nimport os\\nimport shutil\\nimport json\\n\\ndb_path = r\\\"C:\\\\Users\\\\34948\\\\AppData\\\\Roaming\\\\Trae CN\\\\User\\\\workspaceStorage\\\\8522d2f518c4a51a18c0ff9b1e56e46d\\\\state.vscdb\\\"\\ntemp_path = r\\\"c:\\\\Users\\\\34948\\\\Documents\\\\trae_projects\\\\new_project\\\\ws_detail.vscdb\\\"\\n\\nshutil.copy2(db_path, temp_path)\\n\\nconn = sqlite3.connect(temp_path)\\ncur = conn.cursor()\\n\\n# 获取 icube-ai-agent-storage-input-history 的完整 value\\ncur.execute(\\\"SELECT value FROM ItemTable WHERE key='icube-ai-agent-storage-input-history'\\\")\\nrow = cur.fetchone()\\nif row:\\n    value = row[0]\\n    print(f\\\"value 总长度: {len(value)} 字符\\\")\\n\\n    # 尝试解析为 JSON\\n    try:\\n        data = json.loads(value)\\n        print(f\\\"\\\\nJSON 解析成功，类型: {type(data)}\\\")\\n\\n        if isinstance(data, dict):\\n            print(f\\\"字典键数: {len(data)}\\\")\\n            print(f\\\"\\\\n所有键:\\\")\\n            for k in data.keys():\\n                v = data[k]\\n                vlen = len(str(v))\\n                print(f\\\"  {k}  (value长度: {vlen})\\\")\\n\\n            # 搜索包含 test3 或 门户 的键\\n            print(f\\\"\\\\n===== 搜索 test3/门户/new_project 相关键 =====\\\")\\n            for k in data.keys():\\n                if 'test3' in k.lower() or '门户' in k or 'new_project' in k.lower() or 'trae_projects' in k.lower():\\n                    print(f\\\"\\\\n找到键: {k}\\\")\\n                    v = data[k]\\n                    print(f\\\"value 前500字符: {str(v)[:500]}\\\")\\n\\n        elif isinstance(data, list):\\n            print(f\\\"列表项数: {len(data)}\\\")\\n            print(f\\\"\\\\n前3项:\\\")\\n            for i, item in enumerate(data[:3]):\\n                print(f\\\"\\\\n--- 项 {i} ---\\\")\\n                print(str(item)[:500])\\n    except Exception as e:\\n        print(f\\\"JSON 解析失败: {e}\\\")\\n        print(f\\\"\\\\n前2000字符内容:\\\")\\n        print(value[:2000])\\n\\nconn.close()\\nos.remove(temp_path)\\n\",\"originTextLength\":1706,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1783576071337}]"
}